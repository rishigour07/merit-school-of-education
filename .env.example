NEXT_PUBLIC_SITE_URL=https://meritschoolofeducation.vercel.app
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Optional legacy fallback if your Supabase project still uses anon keys.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key

# Server-only. Never prefix this key with NEXT_PUBLIC_ or use it in client code.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
